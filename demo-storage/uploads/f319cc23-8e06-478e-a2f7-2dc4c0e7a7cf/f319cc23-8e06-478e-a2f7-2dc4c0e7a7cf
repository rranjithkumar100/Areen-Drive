<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>A Gift for Dodi</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Cinzel:wght@400;500&family=Lato:wght@300;400&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #1a0a0a;
    font-family: 'Lato', sans-serif;
    overflow: hidden;
  }

  /* Ambient background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 20% 50%, rgba(180,60,60,0.18) 0%, transparent 70%),
      radial-gradient(ellipse 50% 60% at 80% 50%, rgba(120,30,60,0.15) 0%, transparent 70%),
      radial-gradient(ellipse 80% 80% at 50% 50%, rgba(80,10,20,0.4) 0%, transparent 100%);
    pointer-events: none;
  }

  /* Floating petals */
  .petal {
    position: fixed;
    width: 8px;
    height: 12px;
    background: radial-gradient(ellipse at 30% 30%, rgba(220,80,100,0.8), rgba(160,40,60,0.4));
    border-radius: 50% 0 50% 0;
    animation: fall linear infinite;
    pointer-events: none;
  }

  @keyframes fall {
    0%   { transform: translateY(-20px) rotate(0deg) translateX(0); opacity: 0; }
    10%  { opacity: 1; }
    90%  { opacity: 0.6; }
    100% { transform: translateY(110vh) rotate(720deg) translateX(40px); opacity: 0; }
  }

  /* Card */
  .card {
    position: relative;
    width: 420px;
    background: linear-gradient(160deg, #2a0d10 0%, #1c0810 40%, #250d18 100%);
    border: 1px solid rgba(200,100,100,0.2);
    border-radius: 4px;
    padding: 0;
    box-shadow:
      0 0 80px rgba(180,40,60,0.2),
      0 30px 80px rgba(0,0,0,0.8),
      inset 0 0 60px rgba(180,40,60,0.05);
    animation: cardReveal 1.2s cubic-bezier(0.16,1,0.3,1) both;
    overflow: hidden;
  }

  @keyframes cardReveal {
    from { opacity: 0; transform: translateY(30px) scale(0.96); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* Gold border accent */
  .card::before {
    content: '';
    position: absolute;
    inset: 8px;
    border: 1px solid rgba(200,150,80,0.15);
    border-radius: 2px;
    pointer-events: none;
    z-index: 1;
  }

  /* Top decorative band */
  .top-band {
    background: linear-gradient(90deg, transparent, rgba(180,80,80,0.15), rgba(200,120,60,0.1), rgba(180,80,80,0.15), transparent);
    border-bottom: 1px solid rgba(200,100,80,0.2);
    padding: 18px 40px;
    text-align: center;
    position: relative;
  }

  .top-ornament {
    font-family: 'Cinzel', serif;
    font-size: 9px;
    letter-spacing: 4px;
    color: rgba(200,150,100,0.6);
    text-transform: uppercase;
  }

  /* Main content */
  .card-inner {
    padding: 36px 44px 40px;
    position: relative;
    z-index: 2;
  }

  /* Heart */
  .heart-wrap {
    text-align: center;
    margin-bottom: 24px;
    animation: heartbeat 2.5s ease-in-out infinite;
  }

  @keyframes heartbeat {
    0%, 100% { transform: scale(1); }
    14% { transform: scale(1.12); }
    28% { transform: scale(1); }
    42% { transform: scale(1.06); }
    56% { transform: scale(1); }
  }

  .heart {
    font-size: 36px;
    filter: drop-shadow(0 0 16px rgba(220,60,80,0.7));
  }

  /* Title */
  .gift-label {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 5px;
    color: rgba(200,140,80,0.7);
    text-align: center;
    text-transform: uppercase;
    margin-bottom: 10px;
    animation: fadeUp 1s 0.3s both;
  }

  .recipient {
    font-family: 'Cormorant Garamond', serif;
    font-size: 42px;
    font-weight: 300;
    font-style: italic;
    color: #f0d0c0;
    text-align: center;
    line-height: 1.1;
    margin-bottom: 28px;
    text-shadow: 0 0 40px rgba(220,120,80,0.3);
    animation: fadeUp 1s 0.45s both;
  }

  /* Divider */
  .divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 28px;
    animation: fadeUp 1s 0.6s both;
  }

  .divider-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(200,130,80,0.4), transparent);
  }

  .divider-icon { font-size: 14px; opacity: 0.7; }

  /* Service */
  .service-name {
    font-family: 'Cormorant Garamond', serif;
    font-size: 22px;
    font-weight: 400;
    color: #e8c4a8;
    text-align: center;
    margin-bottom: 4px;
    letter-spacing: 1px;
    animation: fadeUp 1s 0.75s both;
  }

  .service-duration {
    font-family: 'Cinzel', serif;
    font-size: 9px;
    letter-spacing: 4px;
    color: rgba(200,140,100,0.6);
    text-align: center;
    text-transform: uppercase;
    margin-bottom: 30px;
    animation: fadeUp 1s 0.85s both;
  }

  /* Message */
  .message {
    font-family: 'Cormorant Garamond', serif;
    font-size: 16px;
    font-style: italic;
    font-weight: 300;
    color: rgba(240,210,190,0.75);
    text-align: center;
    line-height: 1.8;
    margin-bottom: 32px;
    animation: fadeUp 1s 1s both;
  }

  /* Booking details */
  .booking-box {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(200,130,80,0.15);
    border-radius: 2px;
    padding: 18px 22px;
    margin-bottom: 28px;
    animation: fadeUp 1s 1.1s both;
  }

  .booking-title {
    font-family: 'Cinzel', serif;
    font-size: 8px;
    letter-spacing: 4px;
    color: rgba(200,140,80,0.5);
    text-transform: uppercase;
    margin-bottom: 12px;
    text-align: center;
  }

  .booking-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }

  .booking-row:last-child { margin-bottom: 0; }

  .booking-icon {
    font-size: 13px;
    width: 20px;
    text-align: center;
    opacity: 0.8;
  }

  .booking-text {
    font-family: 'Lato', sans-serif;
    font-size: 12px;
    font-weight: 300;
    color: rgba(240,210,190,0.7);
    letter-spacing: 0.5px;
  }

  /* Signature */
  .signature {
    text-align: center;
    animation: fadeUp 1s 1.2s both;
  }

  .with-love {
    font-family: 'Cormorant Garamond', serif;
    font-size: 13px;
    font-weight: 300;
    color: rgba(200,150,120,0.6);
    letter-spacing: 2px;
    margin-bottom: 4px;
  }

  .signer {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-style: italic;
    color: rgba(220,170,130,0.85);
    text-shadow: 0 0 20px rgba(200,100,80,0.3);
  }

  /* Bottom band */
  .bottom-band {
    background: linear-gradient(90deg, transparent, rgba(180,80,80,0.1), rgba(200,120,60,0.08), rgba(180,80,80,0.1), transparent);
    border-top: 1px solid rgba(200,100,80,0.15);
    padding: 14px 40px;
    text-align: center;
  }

  .bottom-text {
    font-family: 'Cinzel', serif;
    font-size: 7px;
    letter-spacing: 4px;
    color: rgba(200,130,80,0.4);
    text-transform: uppercase;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
</head>
<body>

<!-- Floating petals -->
<script>
  const colors = ['rgba(220,80,100,0.7)', 'rgba(180,40,80,0.5)', 'rgba(240,100,80,0.6)'];
  for (let i = 0; i < 18; i++) {
    const p = document.createElement('div');
    p.className = 'petal';
    p.style.left = Math.random() * 100 + 'vw';
    p.style.top = '-20px';
    p.style.animationDuration = (6 + Math.random() * 8) + 's';
    p.style.animationDelay = (Math.random() * 10) + 's';
    p.style.width = (6 + Math.random() * 6) + 'px';
    p.style.height = (8 + Math.random() * 8) + 'px';
    p.style.background = colors[Math.floor(Math.random() * colors.length)];
    p.style.borderRadius = Math.random() > 0.5 ? '50% 0 50% 0' : '0 50% 0 50%';
    document.body.appendChild(p);
  }
</script>

<div class="card">
  <div class="top-band">
    <div class="top-ornament">✦ &nbsp; A Gift of Love &nbsp; ✦</div>
  </div>

  <div class="card-inner">
    <div class="heart-wrap">
      <span class="heart">🌹</span>
    </div>

    <div class="gift-label">This gift is presented to</div>
    <div class="recipient">Dodi</div>

    <div class="divider">
      <div class="divider-line"></div>
      <div class="divider-icon">✦</div>
      <div class="divider-line"></div>
    </div>

    <div class="service-name">Deep Tissue Therapy Massage</div>
    <div class="service-duration">60 Minutes · Full Body · At Home</div>

    <div class="message">
      You give so much of yourself every day.<br>
      This hour belongs entirely to you, my love —<br>
      close your eyes, breathe, and let go of everything.
    </div>

    <div class="booking-box">
      <div class="booking-title">Booking Details</div>
      <div class="booking-row">
        <span class="booking-icon">🗓</span>
        <span class="booking-text">Friday, March 13th at 1:00 AM</span>
      </div>
      <div class="booking-row">
        <span class="booking-icon">🏠</span>
        <span class="booking-text">In the comfort of our home · Al Aarid, Riyadh</span>
      </div>
      <div class="booking-row">
        <span class="booking-icon">✨</span>
        <span class="booking-text">A professional therapist will come to you</span>
      </div>
    </div>

    <div class="signature">
      <div class="with-love">With all my love,</div>
      <div class="signer">Abdulaziz</div>
    </div>
  </div>

  <div class="bottom-band">
    <div class="bottom-text">✦ &nbsp; You deserve every moment of this &nbsp; ✦</div>
  </div>
</div>

</body>
</html>
